<!DOCTYPE html>
<html lang="it">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<script>
if(window.self !== window.top){
  window.top.location.href = window.self.location.href;
}
</script>
<title>Registrazione Armadietto — DLZ3 VAR</title>
<style>
*{box-sizing:border-box;margin:0;padding:0;}
body{font-family:Arial,sans-serif;background:linear-gradient(135deg,#312e81,#4f46e5);min-height:100vh;display:flex;align-items:center;justify-content:center;padding:20px;}
.card{background:#fff;border-radius:20px;width:100%;max-width:500px;overflow:hidden;box-shadow:0 20px 60px rgba(0,0,0,0.3);}
.card-header{background:linear-gradient(90deg,#312e81,#4f46e5);padding:24px 28px;color:#fff;}
.card-header h1{font-size:18px;font-weight:bold;margin-bottom:4px;}
.card-header p{font-size:11px;color:#c7d2fe;letter-spacing:0.5px;}
.card-body{padding:24px 28px;}
.step-label{display:flex;align-items:center;gap:8px;margin-bottom:6px;}
.step-num{background:#4f46e5;color:#fff;border-radius:50%;width:22px;height:22px;display:flex;align-items:center;justify-content:center;font-size:10px;font-weight:bold;flex-shrink:0;}
.step-text{font-size:11px;font-weight:bold;color:#64748b;text-transform:uppercase;letter-spacing:0.5px;}
.field-wrap{margin-bottom:18px;}
.field-wrap input,.field-wrap select,.field-wrap textarea{width:100%;padding:11px 14px;border-radius:8px;border:1.5px solid #e2e8f0;background:#f8fafc;font-size:13px;color:#1e293b;transition:border-color .2s;}
.field-wrap input:focus,.field-wrap select:focus,.field-wrap textarea:focus{outline:none;border-color:#4f46e5;background:#fff;}
.field-wrap input.error,.field-wrap select.error{border-color:#ef4444;background:#fef2f2;}
.err-msg{color:#ef4444;font-size:10px;margin-top:4px;display:none;}
.nota-btn{padding:8px 6px;border-radius:8px;border:1.5px solid #e2e8f0;background:#f8fafc;font-size:11px;font-weight:bold;cursor:pointer;text-align:center;transition:all .15s;}
.nota-btn:hover{border-color:#4f46e5;background:#eff6ff;}
.nota-btn.sel{border-color:#4f46e5;background:#eff6ff;color:#4f46e5;}
.btn-primary{width:100%;padding:13px;background:linear-gradient(90deg,#4f46e5,#7c3aed);color:#fff;border:none;border-radius:10px;font-size:14px;font-weight:bold;cursor:pointer;margin-top:8px;transition:opacity .2s;}
.btn-primary:hover{opacity:.9;}
.btn-primary:disabled{opacity:.5;cursor:not-allowed;}
.btn-green{width:100%;padding:13px;background:linear-gradient(90deg,#22c55e,#16a34a);color:#fff;border:none;border-radius:10px;font-size:14px;font-weight:bold;cursor:pointer;margin-top:8px;}
.btn-outline{width:100%;padding:11px;background:#fff;color:#4f46e5;border:2px solid #4f46e5;border-radius:10px;font-size:13px;font-weight:bold;cursor:pointer;margin-top:8px;transition:all .2s;}
.btn-outline:hover{background:#eff6ff;}
.divider{border:none;border-top:1px solid #e2e8f0;margin:16px 0;}
.info-bar{background:#eff6ff;border:1px solid #c7d2fe;border-radius:8px;padding:10px 14px;margin-bottom:20px;font-size:11px;color:#3730a3;display:flex;align-items:center;gap:8px;}
.success-box{display:none;text-align:center;padding:30px 20px;}
.success-box .icon{font-size:56px;margin-bottom:12px;}
.success-box h2{font-size:18px;font-weight:bold;color:#166534;margin-bottom:8px;}
.success-box p{font-size:12px;color:#64748b;line-height:1.6;}

/* Mappa armadietti */
.mappa-grid{display:flex;flex-wrap:wrap;gap:6px;padding:12px;background:#f8fafc;border-radius:10px;border:1.5px solid #e2e8f0;max-height:260px;overflow-y:auto;}
.arm-cell{width:42px;height:42px;border-radius:8px;display:flex;align-items:center;justify-content:center;font-size:11px;font-weight:bold;cursor:pointer;transition:all .15s;border:2px solid transparent;position:relative;}
.arm-cell.libero{background:#dcfce7;color:#166534;border-color:#86efac;cursor:pointer;}
.arm-cell.libero:hover{background:#22c55e;color:#fff;transform:scale(1.1);}
.arm-cell.libero.sel{background:#22c55e;color:#fff;border-color:#16a34a;transform:scale(1.1);box-shadow:0 0 0 3px rgba(34,197,94,0.3);}
.arm-cell.occupato{background:#fee2e2;color:#94a3b8;border-color:#fca5a5;cursor:not-allowed;opacity:0.6;}
.arm-cell.rotto{background:#f1f5f9;color:#cbd5e1;border-color:#e2e8f0;cursor:not-allowed;opacity:0.4;}
.arm-cell.mio{background:#eff6ff;color:#4f46e5;border-color:#4f46e5;cursor:pointer;}
.arm-cell.mio:hover{background:#4f46e5;color:#fff;}

/* Legenda mappa */
.mappa-legenda{display:flex;gap:12px;flex-wrap:wrap;margin-top:8px;font-size:10px;color:#64748b;}
.leg-item{display:flex;align-items:center;gap:4px;}
.leg-dot{width:12px;height:12px;border-radius:3px;}

/* Card armadietto trovato */
.arm-found-card{background:linear-gradient(135deg,#f0fdf4,#dcfce7);border:2px solid #86efac;border-radius:12px;padding:16px;margin-bottom:14px;}
</style>
</head>
<body>
<div class="card">
  <div class="card-header">
    <h1>🗄 Registrazione Armadietto</h1>
    <p>DELIVERY STATION DLZ3 · VAR 1092</p>
  </div>
  <div class="card-body">

    <!-- STEP 1 — LOGIN E NOME -->
    <div id="step1">
      <div class="info-bar">
        ℹ️ Inserisci il tuo login Amazon per iniziare.
      </div>
      <div class="field-wrap">
        <div class="step-label">
          <div class="step-num">1</div>
          <div class="step-text">Il tuo Login Amazon</div>
        </div>
        <input type="text" id="loginInput" placeholder="es. aarmaanj"
               autocomplete="off" autocapitalize="off"
               oninput="onLoginChange()"/>
        <div class="err-msg" id="errLogin">⚠️ Inserisci il tuo login</div>
      </div>
      <div class="field-wrap">
        <div class="step-label">
          <div class="step-num">2</div>
          <div class="step-text">Nome e Cognome</div>
        </div>
        <input type="text" id="nomeInput" placeholder="es. Mario Rossi" autocomplete="off"/>
        <div class="err-msg" id="errNome">⚠️ Inserisci nome e cognome</div>
      </div>
     
      <button class="btn-primary" onclick="goStep2()">Avanti →</button>
    </div>

    <!-- STEP 2 — ARMADIETTO -->
    <div id="step2" style="display:none;">

      <!-- Intestazione con info persona -->
      <div style="background:#eff6ff;border:1px solid #c7d2fe;border-radius:10px;
                  padding:12px 14px;margin-bottom:16px;display:flex;align-items:center;gap:10px;">
        <div id="s2foto" style="width:40px;height:40px;border-radius:50%;background:#4f46e5;
             color:#fff;display:flex;align-items:center;justify-content:center;
             font-weight:bold;font-size:14px;flex-shrink:0;overflow:hidden;"></div>
        <div>
          <div style="font-size:13px;font-weight:bold;color:#1e293b;" id="s2nome"></div>
          <div style="font-size:11px;color:#6366f1;" id="s2login"></div>
        </div>
        <button onclick="goBackStep1()"
          style="margin-left:auto;background:#f1f5f9;border:1px solid #e2e8f0;
                 border-radius:6px;padding:4px 10px;font-size:10px;color:#64748b;cursor:pointer;">
          ← Modifica
        </button>
      </div>

      <!-- BOX ARMADIETTO TROVATO -->
      <div id="boxTrovato" style="display:none;">
        <div class="arm-found-card">
          <div style="font-size:11px;font-weight:bold;color:#166534;margin-bottom:8px;text-transform:uppercase;">
            ✅ Armadietto trovato nel registro
          </div>
          <div style="display:flex;align-items:center;gap:12px;">
            <div style="background:#22c55e;color:#fff;border-radius:10px;width:54px;height:50px;
                        display:flex;align-items:center;justify-content:center;
                        font-size:18px;font-weight:bold;flex-shrink:0;" id="trovNum"></div>
            <div>
              <div style="font-size:14px;font-weight:bold;color:#1e293b;" id="trovSec"></div>
              <div style="font-size:11px;color:#64748b;margin-top:2px;" id="trovNota"></div>
            </div>
          </div>
        </div>
        <button class="btn-green" onclick="confermaEsistente()">
          ✅ Confermo — è il mio armadietto
        </button>
        <button class="btn-outline" onclick="mostraMappa('cambio')">
          🔄 Voglio cambiare armadietto
        </button>
      </div>

      <!-- BOX NESSUN ARMADIETTO TROVATO -->
      <div id="boxNonTrovato" style="display:none;">
        <div style="background:#fef3c7;border:1.5px solid #fcd34d;border-radius:10px;
                    padding:14px;margin-bottom:14px;text-align:center;">
          <div style="font-size:24px;margin-bottom:6px;">🔍</div>
          <div style="font-size:13px;font-weight:bold;color:#92400e;">
            Nessun armadietto trovato per questo login
          </div>
          <div style="font-size:11px;color:#78350f;margin-top:4px;">
            Seleziona un armadietto libero dalla mappa
          </div>
        </div>
        <button class="btn-primary" onclick="mostraMappa('nuovo')">
          🗺 Scegli armadietto dalla mappa
        </button>
      </div>

      <!-- BOX MAPPA -->
      <div id="boxMappa" style="display:none;">
        <div style="margin-bottom:10px;">
          <div class="step-label">
            <div class="step-num">4</div>
            <div class="step-text">Seleziona spogliatoio</div>
          </div>
          <select id="mappaSecSel" onchange="renderMappa()"
            style="width:100%;padding:10px;border-radius:8px;border:1.5px solid #e2e8f0;
                   font-size:13px;background:#f8fafc;">
          </select>
        </div>

        <div style="margin-bottom:8px;">
          <div class="step-label">
            <div class="step-num">5</div>
            <div class="step-text">Scegli armadietto libero</div>
          </div>
          <div style="font-size:10px;color:#64748b;margin-bottom:6px;" id="mappaFreeCount"></div>
          <div class="mappa-grid" id="mappaGrid"></div>
          <div class="mappa-legenda">
            <div class="leg-item"><div class="leg-dot" style="background:#dcfce7;border:1px solid #86efac;"></div>Libero</div>
            <div class="leg-item"><div class="leg-dot" style="background:#fee2e2;border:1px solid #fca5a5;"></div>Occupato</div>
            <div class="leg-item"><div class="leg-dot" style="background:#22c55e;"></div>Selezionato</div>
          </div>
        </div>

        <!-- Armadietto selezionato -->
        <div id="selBox" style="display:none;background:#f0fdf4;border:2px solid #22c55e;
             border-radius:10px;padding:12px;margin-top:10px;margin-bottom:4px;">
          <div style="font-size:11px;color:#166534;font-weight:bold;margin-bottom:4px;">
            ✅ Armadietto selezionato:
          </div>
          <div style="font-size:20px;font-weight:bold;color:#16a34a;" id="selNum"></div>
          <div style="font-size:11px;color:#64748b;" id="selSec"></div>
        </div>
        <div class="err-msg" id="errArm" style="margin-bottom:8px;">
          ⚠️ Seleziona un armadietto libero
        </div>

        <!-- Sezione NON TROVO — supporto -->
        <div style="margin-top:12px;background:#fef3c7;border:1.5px solid #fcd34d;
                    border-radius:10px;padding:12px;">
          <div style="font-size:11px;font-weight:bold;color:#92400e;margin-bottom:6px;">
            🆘 Non trovi l'armadietto che cerchi?
          </div>
          <div style="font-size:10px;color:#78350f;margin-bottom:8px;">
            Se l'armadietto che desideri è occupato, scrivi qui il numero e il motivo.
            Il manager gestirà la tua richiesta manualmente.
          </div>
          <textarea id="noteInput" placeholder="Es: Vorrei l'armadietto #145 perché... oppure nessun armadietto disponibile nel mio spogliatoio"
            rows="2" style="width:100%;padding:9px;border-radius:7px;border:1.5px solid #fcd34d;
                            background:#fffbeb;font-size:12px;resize:none;"></textarea>
        </div>

        <button class="btn-primary" style="margin-top:12px;" onclick="submitMappa()">
          📤 Invia Richiesta
        </button>
      </div>

    </div>

    <!-- SUCCESS -->
    <div class="success-box" id="successBox">
      <div class="icon">✅</div>
      <h2>Richiesta inviata!</h2>
      <p id="successMsg">Il tuo manager riceverà la notifica.<br/>Verrai contattato per la conferma.</p>
      <p style="margin-top:12px;font-size:11px;color:#94a3b8;">Puoi chiudere questa pagina.</p>
    </div>

  </div>
</div>

<script>
// ═══════════════════════════════════════════════════
// POWER AUTOMATE FLOWS
// ═══════════════════════════════════════════════════
const SP_SITE = 'https://amazon.sharepoint.com/sites/DLZ3';
const FLOW_GET_ARMADIETTI   = 'https://default5280104a472d45389ccf1e1d0efe8b.1b.environment.api.powerplatform.com:443/powerautomate/automations/direct/workflows/f1e0241920d547529bd31a51a348f64f/triggers/manual/paths/invoke?api-version=1&sp=%2Ftriggers%2Fmanual%2Frun&sv=1.0&sig=4-lQkkoEhff0kyZ_dMbXqbTdH1Yforkvbk-9EwKqeZM';
const FLOW_SAVE_RICHIESTA   = 'https://default5280104a472d45389ccf1e1d0efe8b.1b.environment.api.powerplatform.com:443/powerautomate/automations/direct/workflows/17fa5fd1c57843a48d7b688426ec9d30/triggers/manual/paths/invoke?api-version=1&sp=%2Ftriggers%2Fmanual%2Frun&sv=1.0&sig=g0ua5W_xlVlGXweKh2U1mOSLtIR6LYFMCJrf_9mRT58';
const FLOW_UPDATE_ARMADIETTO = 'https://default5280104a472d45389ccf1e1d0efe8b.1b.environment.api.powerplatform.com:443/powerautomate/automations/direct/workflows/e695d5889e8249ddb2ed70aaccf78659/triggers/manual/paths/invoke?api-version=1&sp=%2Ftriggers%2Fmanual%2Frun&sv=1.0&sig=r2R55sHpmoGFkTg7ppwpQboVQtL_-Pvpk_GCPFjnPIw';

// ── STATO ──────────────────────────────────────────
let selectedNota    = 'Non specificato';
let selectedTipo    = '';
let selectedArm     = null;
let tuttiArmadietti = [];
let loginTrovato    = null;

// ── INIT — carica da Armadietti1 ───────────────────
(async function init(){
  try {
    const r = await fetch(FLOW_GET_ARMADIETTI, {method:'POST'});
    if(r.ok){
      const data = await r.json();
      if(Array.isArray(data) && data.length > 0){
        tuttiArmadietti = data;
        console.log('✅ Armadietti caricati:', tuttiArmadietti.length);
      }
    }
  } catch(e){
    console.warn('⚠️ Impossibile caricare armadietti:', e);
  }
})();

// ── HELPERS ────────────────────────────────────────
function isLibero(a){
  const s = (a.Stato||a.nota||'').toUpperCase();
  return !a.Login && !a.NomeCognome && s !== 'ROTTO' && s !== 'OCCUPATO';
}
function isRotto(a){
  return (a.Stato||a.nota||'').toUpperCase() === 'ROTTO';
}
function getSpogliatoi(){
  const set = new Set();
  tuttiArmadietti.forEach(a => { if(a.Spogliatoio) set.add(a.Spogliatoio); });
  return Array.from(set).sort();
}

function initials(nome){
  if(!nome) return '?';
  const p = nome.trim().split(/[\s,]+/).filter(Boolean);
  return p.length >= 2 ? (p[0][0]+p[1][0]).toUpperCase() : (nome[0]||'?').toUpperCase();
}

function onLoginChange(){ loginTrovato = null; }

// ── STEP 1 → STEP 2 ────────────────────────────────
function goStep2(){
  const login = document.getElementById('loginInput').value.trim().toLowerCase();
  const nome  = document.getElementById('nomeInput').value.trim();
  let ok = true;

  if(login.length < 2){
    document.getElementById('errLogin').style.display = 'block';
    ok = false;
  } else {
    document.getElementById('errLogin').style.display = 'none';
  }
  if(nome.length < 3){
    document.getElementById('errNome').style.display = 'block';
    ok = false;
  } else {
    document.getElementById('errNome').style.display = 'none';
  }
  if(!ok) return;

  // Mostra step2
  document.getElementById('step1').style.display = 'none';
  document.getElementById('step2').style.display = 'block';

  // Intestazione persona
  document.getElementById('s2nome').textContent  = nome;
  document.getElementById('s2login').textContent = login;
  const fotoEl = document.getElementById('s2foto');
  fotoEl.textContent = initials(nome);

  // Cerca login nel registro
  cercaLoginNelRegistro(login, nome);
}

function goBackStep1(){
  document.getElementById('step1').style.display = 'block';
  document.getElementById('step2').style.display = 'none';
  document.getElementById('boxTrovato').style.display    = 'none';
  document.getElementById('boxNonTrovato').style.display = 'none';
  document.getElementById('boxMappa').style.display      = 'none';
}

// ── CERCA LOGIN NEL REGISTRO ────────────────────────
function cercaLoginNelRegistro(login, nome){
  document.getElementById('boxTrovato').style.display    = 'none';
  document.getElementById('boxNonTrovato').style.display = 'none';
  document.getElementById('boxMappa').style.display      = 'none';

  if(!tuttiArmadietti || tuttiArmadietti.length === 0){
    document.getElementById('boxNonTrovato').style.display = 'block';
    return;
  }

  // Cerca login in Armadietti1
  const trovato = tuttiArmadietti.find(a =>
    a.Login && a.Login.toLowerCase() === login
  );

  if(trovato){
    loginTrovato = trovato;
    document.getElementById('trovNum').textContent = trovato.Title || trovato.Numero || '—';
    document.getElementById('trovSec').textContent = trovato.Spogliatoio || '—';
    document.getElementById('trovNota').textContent = trovato.Nota
      ? 'Contratto: ' + trovato.Nota
      : 'Armadietto assegnato';
    document.getElementById('boxTrovato').style.display = 'block';
  } else {
    document.getElementById('boxNonTrovato').style.display = 'block';
  }
}

// ── MOSTRA MAPPA ────────────────────────────────────
function mostraMappa(tipo){
  selectedTipo = tipo;
  selectedArm  = null;

  document.getElementById('boxTrovato').style.display    = 'none';
  document.getElementById('boxNonTrovato').style.display = 'none';
  document.getElementById('boxMappa').style.display      = 'block';
  document.getElementById('selBox').style.display        = 'none';

  // Popola select spogliatoi da Armadietti1
  const sel = document.getElementById('mappaSecSel');
  sel.innerHTML = '';
  const spogliatoi = getSpogliatoi();
  spogliatoi.forEach(sp => {
    const op = document.createElement('option');
    op.value       = sp;
    op.textContent = sp;
    sel.appendChild(op);
  });

  renderMappa();
}

// ── RENDER MAPPA ────────────────────────────────────
function renderMappa(){
  const spogliatoio = document.getElementById('mappaSecSel').value;
  const grid  = document.getElementById('mappaGrid');
  grid.innerHTML = '';
  selectedArm = null;
  document.getElementById('selBox').style.display = 'none';

  if(!tuttiArmadietti || tuttiArmadietti.length === 0) return;

  // Filtra per spogliatoio
  const filtrati = tuttiArmadietti.filter(a =>
    a.Spogliatoio === spogliatoio
  ).sort((a,b) => parseInt(a.Title||0) - parseInt(b.Title||0));

  const liberi = filtrati.filter(a => isLibero(a)).length;
  document.getElementById('mappaFreeCount').textContent =
    liberi + ' armadietti liberi su ' + filtrati.length;

  filtrati.forEach(arm => {
    const cell = document.createElement('div');
    cell.className = 'arm-cell';
    cell.textContent = arm.Title || arm.Numero;

    if(isRotto(arm)){
      cell.classList.add('rotto');
      cell.title = '#'+(arm.Title||arm.Numero)+' — Rotto';
    } else if(isLibero(arm)){
      cell.classList.add('libero');
      cell.title = '#'+(arm.Title||arm.Numero)+' — Libero';
      cell.onclick = () => selectArm(cell, arm, spogliatoio);
    } else {
      cell.classList.add('occupato');
      cell.title = '#'+(arm.Title||arm.Numero)+' — Occupato: '+(arm.NomeCognome||arm.Login||'');
    }

    grid.appendChild(cell);
  });
}

// ── SELEZIONA ARMADIETTO DALLA MAPPA ───────────────
function selectArm(cell, arm, spogliatoio){
  document.querySelectorAll('.arm-cell.libero').forEach(c => c.classList.remove('sel'));
  cell.classList.add('sel');

  selectedArm = { n: arm.Title||arm.Numero, spogliatoio };

  document.getElementById('selNum').textContent = '#' + (arm.Title||arm.Numero);
  document.getElementById('selSec').textContent = spogliatoio;
  document.getElementById('selBox').style.display = 'block';
  document.getElementById('errArm').style.display = 'none';
}

// ── CONFERMA ARMADIETTO ESISTENTE ──────────────────
function confermaEsistente(){
  if(!loginTrovato) return;
  selectedTipo = 'conferma';
  const login = document.getElementById('loginInput').value.trim().toLowerCase();
  const nome  = document.getElementById('nomeInput').value.trim();
  const numero = loginTrovato.Title || loginTrovato.Numero || '—';
  const spogliatoio = loginTrovato.Spogliatoio || '—';

  mostraConfermaPopup(
    nome, login, spogliatoio, numero, 'conferma',
    () => inviaRichiesta({
      tipo:        'conferma',
      spogliatoio: spogliatoio,
      numero:      String(numero),
      note:        ''
    })
  );
}

// ── SUBMIT DALLA MAPPA ──────────────────────────────
function submitMappa(){
  const note = document.getElementById('noteInput').value.trim();

  // Se non ha selezionato armadietto ma ha scritto nota — richiesta supporto
  if(!selectedArm && note.length > 5){
    selectedTipo = 'supporto';
    const login = document.getElementById('loginInput').value.trim().toLowerCase();
    const nome  = document.getElementById('nomeInput').value.trim();
    const secSel = document.getElementById('mappaSecSel');
    const secName = secSel.options[secSel.selectedIndex]?.text || '';

    inviaRichiesta({
      tipo:        'supporto',
      spogliatoio: secName,
      numero:      '0',
      note:        note
    });
    return;
  }

  // Deve aver selezionato armadietto
  if(!selectedArm){
    document.getElementById('errArm').style.display = 'block';
    return;
  }

  const login = document.getElementById('loginInput').value.trim().toLowerCase();
  const nome  = document.getElementById('nomeInput').value.trim();

  // ── Armadietto libero selezionato — auto-conferma ──
  const tipo = selectedTipo === 'cambio' ? 'cambio_autoconfermato' : 'nuovo_autoconfermato';

  mostraConfermaPopup(
    nome, login, selectedArm.spogliatoio, selectedArm.n, tipo,
    () => inviaRichiesta({
      tipo,
      spogliatoio: selectedArm.spogliatoio,
      numero:      String(selectedArm.n),
      note:        note
    })
  );
}

// ── POPUP CONFERMA ──────────────────────────────────
function mostraConfermaPopup(nome, login, spogliatoio, numero, tipo, onConfirm){
  const tipoLabel = tipo === 'conferma' ? '✅ Conferma armadietto' :
                    tipo === 'cambio'   ? '🔄 Cambio armadietto'  :
                    tipo === 'supporto' ? '🆘 Richiesta supporto' :
                                         '🆕 Nuovo armadietto';

  const box = document.createElement('div');
  box.style.cssText = 'position:fixed;inset:0;background:rgba(15,23,42,.9);z-index:999;display:flex;align-items:center;justify-content:center;padding:20px;';
  box.innerHTML = `
    <div style="background:#fff;border-radius:16px;max-width:420px;width:100%;overflow:hidden;box-shadow:0 20px 60px #00000060;">
      <div style="background:linear-gradient(90deg,#4f46e5,#7c3aed);padding:20px 24px;text-align:center;">
        <div style="font-size:36px;margin-bottom:6px;">📋</div>
        <div style="color:#fff;font-size:17px;font-weight:bold;">Conferma Richiesta</div>
        <div style="color:#c7d2fe;font-size:11px;margin-top:3px;">Controlla i dati prima di inviare</div>
      </div>
      <div style="padding:20px;">
        <div style="background:#eff6ff;border:2px solid #4f46e5;border-radius:10px;padding:16px;margin-bottom:14px;text-align:center;">
          <div style="background:#4f46e5;border-radius:20px;padding:4px 14px;font-size:11px;font-weight:bold;color:#fff;margin-bottom:10px;display:inline-block;">
            ${tipoLabel}
          </div>
          <div style="font-size:28px;font-weight:bold;color:#4f46e5;">${numero !== '0' ? '#'+numero : '🆕'}</div>
          <div style="font-size:13px;font-weight:bold;color:#1e293b;margin-top:4px;">${spogliatoio}</div>
          <div style="font-size:11px;color:#6366f1;margin-top:4px;">${nome} · ${login}</div>
          <div style="font-size:10px;color:#94a3b8;margin-top:2px;">Contratto: ${selectedNota||'Non specificato'}</div>
        </div>
        <div style="background:#f0fdf4;border:1px solid #86efac;border-radius:8px;padding:10px;margin-bottom:14px;font-size:11px;color:#166534;line-height:1.8;">
          ✅ I dati inseriti sono corretti<br>
          ✅ ${numero !== '0' ? 'Sono davanti all\'armadietto <strong>#'+numero+'</strong>' : 'Richiedo supporto al manager'}
        </div>
        <div style="background:#fef2f2;border:1px solid #fca5a5;border-radius:8px;padding:8px 12px;margin-bottom:14px;font-size:10px;color:#dc2626;">
          ⚠️ Se i dati non sono corretti premi ANNULLA e correggi.
        </div>
        <div style="display:flex;gap:10px;">
          <button onclick="this.closest('div[style*=fixed]').remove()"
            style="flex:1;padding:12px;background:#f1f5f9;color:#475569;border:1px solid #e2e8f0;border-radius:8px;font-size:12px;font-weight:bold;cursor:pointer;">
            ✖ Annulla
          </button>
          <button id="btnOkPopup"
            style="flex:2;padding:12px;background:linear-gradient(90deg,#22c55e,#16a34a);color:#fff;border:none;border-radius:8px;font-size:13px;font-weight:bold;cursor:pointer;">
            ✅ Sì, Confermo
          </button>
        </div>
      </div>
    </div>`;

  document.body.appendChild(box);
  document.getElementById('btnOkPopup').onclick = () => {
    box.remove();
    onConfirm();
  };
}

// ── INVIA RICHIESTA ─────────────────────────────────
async function inviaRichiesta({ tipo, spogliatoio, numero, note }){
  const login = document.getElementById('loginInput').value.trim().toLowerCase();
  const nome  = document.getElementById('nomeInput').value.trim();
  const id    = 'REQ-' + Date.now();
  const dataOra = new Date().toLocaleDateString('it-IT') + ' ' +
                  new Date().toLocaleTimeString('it-IT',{hour:'2-digit',minute:'2-digit'});

  try {
    // Invia richiesta tramite Power Automate — RiceviRichiestaArmadietto → ArmadiettRequests
    const dataConferma = (tipo === 'conferma' || tipo === 'nuovo_autoconfermato' || tipo === 'cambio_autoconfermato')
      ? new Date().toLocaleDateString('it-IT')+' '+new Date().toLocaleTimeString('it-IT',{hour:'2-digit',minute:'2-digit'})
      : '';

    await fetch(FLOW_SAVE_RICHIESTA, {
      method: 'POST',
      headers: {'Content-Type': 'application/json'},
      body: JSON.stringify({
        Login:        login,
        NomeCognome:  nome,
        EmployeID:    '',
        Armadietto:   String(numero),
        Spogliatoio:  spogliatoio,
        Stato:        tipo === 'conferma' || tipo === 'nuovo_autoconfermato' || tipo === 'cambio_autoconfermato' ? 'Gestita' : 'In attesa',
        Note:         note || '',
        DataRichiesta: new Date().toISOString(),
        DataConferma:  dataConferma
      })
    });

    // ── SE ARMADIETTO CONFERMATO — aggiorna Armadietti1 ──
    if(tipo === 'conferma' || tipo === 'nuovo_autoconfermato' || tipo === 'cambio_autoconfermato'){
      // Trova l'spId dell'armadietto
      const arm = tuttiArmadietti.find(a => String(a.Title||a.Numero) === String(numero));
      const spId = arm ? (arm.ID || arm.Id) : null;
      if(spId){
        await fetch(FLOW_UPDATE_ARMADIETTO, {
          method: 'POST',
          headers: {'Content-Type': 'application/json'},
          body: JSON.stringify({
            spId:       spId,
            stato:      selectedNota || 'BB',
            login:      login,
            nome:       nome,
            nota:       selectedNota || 'BB',
            confermato: dataConferma
          })
        });
      }
    }

    // Messaggio successo
    const msg = tipo === 'conferma' || tipo === 'nuovo_autoconfermato' || tipo === 'cambio_autoconfermato'
      ? '✅ Armadietto <strong>#'+numero+'</strong> confermato automaticamente!<br/>Nessun intervento necessario.'
      : tipo === 'supporto'
      ? '🆘 Richiesta di supporto inviata.<br/>Il manager ti contatterà a breve.'
      : tipo === 'cambio'
      ? '🔄 Richiesta di cambio inviata.<br/>Il manager la gestirà a breve.'
      : '🆕 Richiesta inviata.<br/>Il manager la gestirà a breve.';

    document.getElementById('step1').style.display      = 'none';
    document.getElementById('step2').style.display      = 'none';
    document.getElementById('successMsg').innerHTML     = msg;
    document.getElementById('successBox').style.display = 'block';

  } catch(e){
    console.error('Errore invio:', e);
    alert('❌ Errore invio. Riprova.');
  }
}
</script>
